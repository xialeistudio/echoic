DATABASE_URL=postgresql://echoic:echoic@localhost:5432/echoic
# macOS only: espeak-ng library path for phonemizer
# PHONEMIZER_ESPEAK_LIB=/opt/homebrew/lib/libespeak-ng.dylib
CORS_ORIGINS='["http://localhost:5173"]'

# ── ASR ───────────────────────────────────────────────────────────────────────
# WhisperX uses CTranslate2 which does NOT support MPS (Apple Silicon GPU)
# macOS M-series:  DEVICE=cpu, COMPUTE_TYPE=int8
# Linux + CUDA:    DEVICE=cuda, COMPUTE_TYPE=float16
# MODEL_SIZE options: tiny / base / small / medium / large-v2
ASR__BACKEND=whisperx
ASR__WHISPERX__MODEL_SIZE=small
ASR__WHISPERX__DEVICE=cpu
ASR__WHISPERX__COMPUTE_TYPE=int8
ASR__WHISPERX__LANGUAGE=en
ASR__WHISPERX__BATCH_SIZE=16

# ── Alignment ─────────────────────────────────────────────────────────────────
# wav2vec2 uses PyTorch — MPS IS supported on Apple Silicon
# macOS M-series:  DEVICE=mps
# Linux + CUDA:    DEVICE=cuda
# CPU fallback:    DEVICE=cpu
ALIGNMENT__BACKEND=wav2vec2
ALIGNMENT__WAV2VEC2__DEVICE=mps

# ── Scoring ───────────────────────────────────────────────────────────────────
# Same as alignment — PyTorch, MPS supported
SCORING__BACKEND=phoneme
SCORING__PHONEME__DEVICE=mps

# ── Scoring weights ───────────────────────────────────────────────────────────
SCORING__PHONEME__ACCURACY_WEIGHT=0.5
SCORING__PHONEME__FLUENCY_WEIGHT=0.3
SCORING__PHONEME__COMPLETENESS_WEIGHT=0.2

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE__BACKEND=local
STORAGE__LOCAL_DIR=storage
# S3 (set STORAGE__BACKEND=s3 to enable)
# STORAGE__S3_BUCKET=your-bucket
# STORAGE__S3_PREFIX=echoic/

# ── LLM (optional — translation + sentence analysis) ──────────────────────────
# OpenAI (or any OpenAI-compatible API)
# LLM__BACKEND=openai
# LLM__OPENAI__API_KEY=sk-...
# LLM__OPENAI__MODEL=gpt-4o-mini
# LLM__OPENAI__BASE_URL=https://api.openai.com/v1

# Ollama (local inference, no API key required)
# LLM__BACKEND=ollama
# LLM__OLLAMA__BASE_URL=http://localhost:11434
# LLM__OLLAMA__MODEL=qwen2.5:2b
# LLM__OLLAMA__NUM_CTX=512    # increase to 4096+ if THINK=true
# LLM__OLLAMA__THINK=false    # enable qwen3.5 thinking mode (better quality, more memory)

# ── yt-dlp (optional — YouTube cookie auth) ───────────────────────────────────
# YouTube may require login to avoid bot detection.
# Set to your browser name to use its cookies: chrome | firefox | safari | edge
# YTDLP__COOKIES_FROM_BROWSER=chrome
